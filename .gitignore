# ── macOS ──────────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Python ─────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
*.egg-info/

# ── Node / Next.js ─────────────────────────────────────────────────────────────
node_modules/
.next/
out/
next-env.d.ts
*.tsbuildinfo
npm-debug.log*

# ── Secrets & environment ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep .env.example and .env.local.example — they are safe templates

# ── Database & user data ───────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/uploads/**
!backend/uploads/.gitkeep

# ── Runtime / generated ────────────────────────────────────────────────────────
*.log
backend/usage.json

# ── Mac app generated assets (rebuilt from logo.png on first launch) ──────────
frontend/public/favicon.png

# ── Dependency hash sentinels (auto-generated by launcher, not source) ─────────
backend/.deps_hash
frontend/.pkg_hash
frontend/.build_hash

# ── PyInstaller / distribution build output ───────────────────────────────────
dist/
build/
*.spec.bak

# ── Windows launcher-generated files (rebuilt from logo.png on first run) ──────
DeutschPath.ico
DeutschPath.lnk

# ── Local verification artifacts (screenshots, test scripts) ──────────────────
scratchpad/
